<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DistributedFractals.Gui.Views.ConfirmDialog"
        Title="Warning"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBgBrush}">

    <Border Background="{StaticResource AppBgBrush}"
            BorderBrush="{StaticResource AppBorderBrush}"
            BorderThickness="1">
        <StackPanel Margin="24" Spacing="20" Width="320">

            <StackPanel Spacing="8">
                <TextBlock x:Name="TitleText"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource AppTextBrush}" />
                <TextBlock x:Name="MessageText"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource AppTextMutedBrush}" />
            </StackPanel>

            <Grid ColumnDefinitions="*,8,*">
                <Button Grid.Column="0"
                        x:Name="CancelButton"
                        Classes="muted"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Padding="0,10"
                        Click="OnCancelClick" />
                <Button Grid.Column="2"
                        x:Name="ConfirmButton"
                        Classes="accent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Padding="0,10"
                        Click="OnConfirmClick" />
            </Grid>

        </StackPanel>
    </Border>

</Window>
